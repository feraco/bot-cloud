# BotBrain Production Environment Configuration
# Copy this file to .env.production and fill in your values

# ==========================================
# Domain Configuration
# ==========================================
# Your domain name pointing to the cloud VM
DOMAIN=botbrain.yourdomain.com

# Email for Let's Encrypt certificate notifications
CADDY_EMAIL=admin@yourdomain.com

# ==========================================
# Supabase Configuration
# ==========================================
# Get these from your Supabase project dashboard
# Project Settings > API

# Your Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anonymous/public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ==========================================
# Application URLs
# ==========================================
# Public URL where BotBrain will be accessible
NEXT_PUBLIC_APP_URL=https://botbrain.yourdomain.com

# Default ROS WebSocket port (robots listen on this port)
NEXT_PUBLIC_ROS_PORT=9090

# Internal port for frontend container (don't change)
PORT=3000

# ==========================================
# z4rtc Bridge Configuration
# ==========================================
# Public URL for z4rtc bridge API
Z4RTC_BRIDGE_URL=https://botbrain.yourdomain.com/z4rtc

# Internal port for z4rtc bridge (don't change)
Z4RTC_BRIDGE_PORT=8787

# Command to run z4rtc (default assumes z4rtc is in ./z4rtc/)
Z4RTC_COMMAND=python3 /opt/z4rtc/z4rtc.py

# Allow raw z4rtc commands (set to true only if you need advanced features)
Z4RTC_ALLOW_RAW_COMMANDS=false

# Healthcheck command for z4rtc connections
Z4RTC_HEALTHCHECK_COMMAND=run_ip_address

# Command timeout in seconds
Z4RTC_COMMAND_TIMEOUT=20

# ==========================================
# Unitree Cloud Configuration (Optional)
# ==========================================
# Only needed if you're using z4rtc in cloud mode for Unitree robots
# Leave empty if using local IP mode or don't have Unitree robots

# Your Unitree cloud account email
UNITREE_CLOUD_EMAIL=

# Your Unitree cloud account password
UNITREE_CLOUD_PASSWORD=

# ==========================================
# Tailscale Configuration (Optional)
# ==========================================
# These are usually not needed as environment variables
# Tailscale is configured via CLI: tailscale up

# If you want to set a specific hostname for the VM:
# Run: sudo tailscale set --hostname botbrain-cloud

# To advertise routes (advanced):
# Run: sudo tailscale up --advertise-routes=10.0.0.0/24

# ==========================================
# Security and Performance
# ==========================================

# Enable telemetry (set to 0 to disable)
NEXT_TELEMETRY_DISABLED=1

# Node environment (leave as production)
NODE_ENV=production

# ==========================================
# Monitoring and Logging (Optional)
# ==========================================

# Log level for application
LOG_LEVEL=info

# Sentry DSN for error tracking (optional)
# SENTRY_DSN=

# ==========================================
# Notes
# ==========================================
#
# Required for cloud deployment:
# - DOMAIN
# - CADDY_EMAIL
# - NEXT_PUBLIC_SUPABASE_URL
# - NEXT_PUBLIC_SUPABASE_ANON_KEY
# - NEXT_PUBLIC_APP_URL
#
# Optional but recommended:
# - UNITREE_CLOUD_EMAIL (if using Unitree robots with z4rtc cloud mode)
# - UNITREE_CLOUD_PASSWORD (if using Unitree robots with z4rtc cloud mode)
#
# After changing any NEXT_PUBLIC_* variables, rebuild the frontend:
# docker compose -f docker-compose.production.yaml build frontend
#
# Secrets management:
# - Keep this file secure (never commit to git)
# - Use strong passwords
# - Rotate credentials regularly
# - Back up this file securely
#
# For local development:
# - Use .env.local in the frontend/ directory
# - Point to localhost or LAN IPs
# - See frontend/.env.example for local configuration
